# Copie para .env na raiz e preencha. Usado pelo docker-compose.

JWT_SECRET=minhaChaveSuperSecreta
zapApiToken=SEU_ZAP_API_TOKEN
zapApiInstance=SUA_INSTANCIA
zapApiClientToken=SEU_CLIENT_TOKEN

CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=seu_api_secret

EMAIL_USER=seu-email@dominio.com
EMAIL_PASSWORD=senha_do_email

# Opcional - link do cardápio (webhook Z-API)
CARDAPIO_LINK=https://seu-dominio.com.br
